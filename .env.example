# Telegram-бот для приёма заявок с сайта.
# 1) Создай бота через @BotFather в Telegram, получи TOKEN
# 2) Напиши боту любое сообщение, потом открой:
#    https://api.telegram.org/bot<ТВОЙ_ТОКЕН>/getUpdates
#    в поле "chat":{"id": ... } — это твой CHAT_ID
# 3) Подставь сюда. Если этих переменных нет — заявки будут писаться в логи сервера.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
